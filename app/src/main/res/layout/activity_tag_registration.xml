<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_launch">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:contentDescription="@string/desc_back"
        android:padding="4dp"
        android:src="@drawable/baseline_arrow_back"
        app:tint="@color/white"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/title_stock_registration"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:fontFamily="@font/raleway_bold"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        tools:ignore="TextContrastCheck"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintEnd_toStartOf="@id/ivReaderBattery"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack" />

    <ImageView
        android:id="@+id/ivReaderBattery"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_battery_indicator"
        android:visibility="gone"
        android:layout_marginEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/whiteContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_white_rounded_top"
        android:elevation="16dp"
        android:outlineProvider="background"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Item Search Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardItemSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardElevation="4dp"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <LinearLayout
                    android:id="@+id/layoutItemLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/tvItemLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Item"
                        android:textColor="@color/blue_theme"
                        android:textSize="13sp"
                        android:fontFamily="@font/raleway_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" *"
                        android:textColor="@color/red"
                        android:textSize="13sp"
                        android:fontFamily="@font/raleway_bold" />
                </LinearLayout>

                <AutoCompleteTextView
                    android:id="@+id/actvItemSearch"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginTop="6dp"
                    android:paddingHorizontal="12dp"
                    android:hint="Search item..."
                    android:textSize="14sp"
                    android:fontFamily="@font/raleway_bold"
                    android:textColor="@color/black"
                    android:textColorHint="#AAAAAA"
                    android:background="@drawable/bg_edittext_rounded"
                    android:completionThreshold="1"
                    android:inputType="text"
                    android:imeOptions="actionDone"
                    app:layout_constraintTop_toBottomOf="@id/layoutItemLabel"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />


            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Power + Status Bar -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardScanned"
            android:layout_width="match_parent"
            android:layout_height="47dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="25dp"
            app:cardBackgroundColor="@color/blue_theme"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/cardItemSearch">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="4dp">

                <Spinner
                    android:id="@+id/spinnerPower"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_spinner"
                    android:popupBackground="@drawable/bg_spinner_dropdown"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:ignore="TouchTargetSizeCheck" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Single Tag Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardlistTag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="10dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/cardScanned"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvListTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_list_tag"
                    android:textColor="@color/blue_theme"
                    android:textSize="16sp"
                    android:fontFamily="@font/raleway_extra_bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvProcessing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Validating tag..."
                    android:textColor="@color/blue_theme"
                    android:textSize="13sp"
                    android:fontFamily="@font/raleway_bold"
                    android:visibility="gone"
                    android:layout_marginTop="4dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvListTitle" />

                <!-- Empty state -->
                <LinearLayout
                    android:id="@+id/tvEmpty"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="visible"
                    app:layout_constraintTop_toBottomOf="@id/tvProcessing"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_box"
                        app:tint="#CCCCCC"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/label_empty_no_tags"
                        android:textColor="#AAAAAA"
                        android:fontFamily="@font/raleway_bold"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Tag single item display -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTags"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/tvProcessing"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:listitem="@layout/item_tag_regist" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bottom Buttons -->
        <LinearLayout
            android:id="@+id/bottomButtonsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/red"
                android:fontFamily="@font/raleway_bold"
                android:stateListAnimator="@null"
                android:text="@string/action_clear"
                android:elevation="2dp"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="20dp"
                tools:ignore="ButtonStyle" />

            <Button
                android:id="@+id/btnSubmitRegis"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:fontFamily="@font/raleway_bold"
                android:backgroundTint="@color/green_button"
                android:stateListAnimator="@null"
                android:text="@string/action_save"
                android:elevation="2dp"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="20dp"
                tools:ignore="TextContrastCheck,ButtonStyle" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFabLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:strokeColor="#F57C00"
            app:strokeWidth="3dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/bottomButtonsContainer">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabLog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Activity Log"
                android:src="@drawable/ic_log"
                app:tint="#F57C00"
                app:backgroundTint="@color/white"
                app:fabSize="mini"
                app:borderWidth="0dp"
                app:elevation="0dp" />

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>