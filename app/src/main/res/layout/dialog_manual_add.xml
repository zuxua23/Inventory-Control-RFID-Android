<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    android:elevation="10dp"
    android:layout_margin="16dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_title_dialog_manual_add"
            android:textSize="20sp"
            android:fontFamily="@font/raleway_bold"
            android:textColor="@color/black"
            android:textAlignment="center"
            android:layout_marginBottom="20dp" />

        <!-- Item label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Item"
            android:textSize="11sp"
            android:fontFamily="@font/raleway_bold"
            android:textColor="@color/black"
            android:alpha="0.5"
            android:layout_marginBottom="4dp" />

        <!-- Item field (disabled) -->
        <EditText
            android:id="@+id/etManualItemId"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_edit_text"
            android:hint="@string/hint_manual_item_id"
            android:paddingHorizontal="16dp"
            android:fontFamily="@font/raleway_bold"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp"
            android:inputType="text"
            android:importantForAutofill="no"
            tools:ignore="all" />

        <!-- Scan Tag label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Replacement Tag"
            android:textSize="11sp"
            android:fontFamily="@font/raleway_bold"
            android:textColor="@color/black"
            android:alpha="0.5"
            android:layout_marginBottom="8dp" />

        <!-- Tag result card — hidden until scan succeeds -->
        <FrameLayout
            android:id="@+id/frameTagResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <include layout="@layout/item_manual_tag" />

        </FrameLayout>

        <!-- Placeholder shown before any scan -->
        <LinearLayout
            android:id="@+id/layoutTagPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_edit_text"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Point scanner at tag to scan..."
                android:textSize="12sp"
                android:fontFamily="@font/raleway_regular"
                android:textColor="@color/black"
                android:alpha="0.35" />

        </LinearLayout>

        <!-- Remark label -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remark"
                android:textSize="11sp"
                android:fontFamily="@font/raleway_bold"
                android:textColor="@color/black"
                android:alpha="0.5" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" *"
                android:textSize="14sp"
                android:fontFamily="@font/raleway_bold"
                android:textColor="@color/red" />
        </LinearLayout>

        <EditText
            android:id="@+id/etManualRemark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:background="@drawable/bg_edit_text"
            android:hint="@string/hint_manual_remark"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:fontFamily="@font/raleway_regular"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_marginBottom="24dp"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:minLines="2"
            android:maxLines="5"
            android:scrollbars="vertical"
            android:importantForAutofill="no"
            tools:ignore="all" />

        <!-- Buttons -->
        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnCancelManual"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#7A7C7D"
                android:text="@string/dialog_cancel"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:fontFamily="@font/raleway_bold"
                app:cornerRadius="16dp"
                tools:ignore="all" />

            <Button
                android:id="@+id/btnSaveManual"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:fontFamily="@font/raleway_bold"
                android:backgroundTint="@color/green_button"
                android:stateListAnimator="@null"
                android:text="@string/action_save"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="20dp"
                tools:ignore="all" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>